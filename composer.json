{
    "name": "brotkrueml/typo3-form-rate-limit",
    "description": "TYPO3 form finisher for rate limiting when sending a form",
    "license": "GPL-2.0-or-later",
    "type": "typo3-cms-extension",
    "version": "2.1.0-dev",
    "authors": [
        {
            "name": "Chris Müller",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/brotkrueml/typo3-form-rate-limit/issues",
        "source": "https://github.com/brotkrueml/typo3-form-rate-limit",
        "docs": "https://docs.typo3.org/p/brotkrueml/typo3-form-rate-limit/main/en-us/"
    },
    "require": {
        "php": ">=8.2",
        "symfony/rate-limiter": "^7.2",
        "typo3/cms-core": "^13.4.10 || ^14.2",
        "typo3/cms-fluid": "^13.4.10 || ^14.2",
        "typo3/cms-form": "^13.4.10 || ^14.2"
    },
    "require-dev": {
        "brotkrueml/coding-standards": "~6.3.1",
        "ergebnis/composer-normalize": "~2.50.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "2.1.44",
        "phpunit/phpunit": "^11.5 || ^12.5 || ^13.0",
        "rector/rector": "2.3.9",
        "symfony/yaml": "^7.4",
        "symplify/phpstan-rules": "^14.9",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "typo3/cms-install": "^13.4.10 || ^14.2",
        "typo3/testing-framework": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Brotkrueml\\FormRateLimit\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brotkrueml\\FormRateLimit\\Tests\\": "Tests"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "phpstan/extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "vendor-dir": ".Build/vendor"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.1.x-dev"
        },
        "typo3/cms": {
            "Package": {
                "providesPackages": {
                    "symfony/rate-limiter": ""
                }
            },
            "extension-key": "form_rate_limit",
            "web-dir": ".Build/web"
        }
    }
}
